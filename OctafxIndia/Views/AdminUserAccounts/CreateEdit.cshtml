@model OctafxIndia.Models.UserTradingAccount

@{
    var isNew = Model == null || Model.Id == 0;
    ViewData["Title"] = isNew ? "Create Trading Account" : "Edit Trading Account";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="mb-0">@ViewData["Title"]</h3>

        <a asp-action="Index"
           asp-controller="AdminUserAccounts"
           class="btn btn-outline-secondary">
            Back to list
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    @if (TempData["CreateErrors"] != null)
    {
        <div class="alert alert-danger">
            Error: @TempData["CreateErrors"]
        </div>
    }

    @if (TempData["EditErrors"] != null)
    {
        <div class="alert alert-danger">
            Error: @TempData["EditErrors"]
        </div>
    }

    <div class="card mt-3 shadow-sm">
        <div class="card-body">

            <form asp-action="CreateEdit"
                  asp-controller="AdminUserAccounts"
                  method="post"
                  novalidate>

                @Html.AntiForgeryToken()

                <!-- Hidden Id for edit mode -->
                <input asp-for="Id" type="hidden" />

                <!-- Validation Summary -->
                @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

                <div class="mb-3">
                    <label asp-for="AccountNumber" class="form-label">
                        Account Number
                    </label>

                    <input asp-for="AccountNumber" class="form-control" />

                    <span asp-validation-for="AccountNumber"
                          class="text-danger">
                    </span>
                </div>

                <div class="mb-3">
                    <label asp-for="AccountType" class="form-label">
                        Account Type
                    </label>

                    <input asp-for="AccountType" class="form-control" />

                    <div class="form-text">
                        Example: REAL or DEMO
                    </div>

                    <span asp-validation-for="AccountType"
                          class="text-danger">
                    </span>
                </div>

                <div class="mb-3">
                    <label asp-for="Server" class="form-label">
                        Server
                    </label>

                    <input asp-for="Server" class="form-control" />

                    <span asp-validation-for="Server"
                          class="text-danger">
                    </span>
                </div>

                <div class="row">

                    <div class="col-md-4 mb-3">
                        <label asp-for="Balance" class="form-label">
                            Balance
                        </label>

                        <input asp-for="Balance"
                               class="form-control"
                               type="number"
                               step="0.01" />

                        <span asp-validation-for="Balance"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="Equity" class="form-label">
                            Equity
                        </label>

                        <input asp-for="Equity"
                               class="form-control"
                               type="number"
                               step="0.01" />

                        <span asp-validation-for="Equity"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="Status" class="form-label">
                            Status
                        </label>

                        <input asp-for="Status" class="form-control" />

                        <span asp-validation-for="Status"
                              class="text-danger">
                        </span>
                    </div>

                </div>

                <div class="d-flex gap-2">

                    <button type="submit"
                            class="btn btn-primary">
                        Save
                    </button>

                    <a asp-action="Index"
                       asp-controller="AdminUserAccounts"
                       class="btn btn-secondary">
                        Cancel
                    </a>

                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

