@model IEnumerable<OctafxIndia.Models.UserTradingAccount>
@{
    ViewData["Title"] = "Manage Trading Accounts";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>@ViewData["Title"]</h3>
        <a asp-action="Create" class="btn btn-primary">Create account</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Id</th>
                            <th>Account Number</th>
                            <th>Type</th>
                            <th>Server</th>
                            <th>Balance</th>
                            <th>Equity</th>
                            <th>Status</th>
                            <th style="width:170px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var a in Model)
                        {
                            <tr>
                                <td>@a.Id</td>
                                <td>@a.AccountNumber</td>
                                <td>@a.AccountType</td>
                                <td>@(string.IsNullOrEmpty(a.Server) ? "-" : a.Server)</td>
                                <td>@a.Balance.ToString("C")</td>
                                <td>@a.Equity.ToString("C")</td>
                                <td>@(string.IsNullOrEmpty(a.Status) ? "-" : a.Status)</td>
                                <td>
                                    <a asp-action="Edit" asp-route-id="@a.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                                    <form asp-action="Delete" asp-route-id="@a.Id" method="post" class="d-inline-block" onsubmit="return confirm('Delete this account?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
