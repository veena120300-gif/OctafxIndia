    <script>
        /* ===========================
           RIGHT PANEL + SUBMENUS
           =========================== */
        (function () {
            const panel   = document.getElementById('rightPanel');
            const toggle  = document.getElementById('menuToggle');
            const closeBtn = document.getElementById('closeRightPanel');
            const toggles = document.querySelectorAll('.nav-link.nav-toggle');

            function openPanel() {
                if (!panel) return;
                panel.classList.add('open');
                panel.setAttribute('aria-hidden', 'false');
                if (toggle) toggle.setAttribute('aria-expanded', 'true');
            }

            function closePanel() {
                if (!panel) return;
                panel.classList.remove('open');
                panel.setAttribute('aria-hidden', 'true');
                if (toggle) toggle.setAttribute('aria-expanded', 'false');
            }

            function closeAllSubmenus() {
                toggles.forEach(t => t.setAttribute('aria-expanded', 'false'));
                document.querySelectorAll('.nav-submenu').forEach(s => s.hidden = true);
            }

            // open/close right side panel via burger
            if (toggle) {
                toggle.addEventListener('click', function (e) {
                    e.stopPropagation();
                    if (panel && panel.classList.contains('open')) closePanel(); else openPanel();
                });
            }

            if (closeBtn) {
                closeBtn.addEventListener('click', function (e) {
                    e.stopPropagation();
                    closePanel();
                });
            }

            // submenu toggles
            toggles.forEach(btn => {
                btn.addEventListener('click', function (e) {
                    e.preventDefault();
                    const targetId = this.dataset.target;
                    if (!targetId) return;
                    const submenu = document.getElementById(targetId);
                    if (!submenu) return;

                    const isOpen = this.getAttribute('aria-expanded') === 'true';
                    closeAllSubmenus();

                    if (!isOpen) {
                        this.setAttribute('aria-expanded', 'true');
                        submenu.hidden = false;
                    }
                });
            });

            // click outside closes panel & submenus
            document.addEventListener('click', (e) => {
                if (panel && !panel.contains(e.target) && toggle && !toggle.contains(e.target)) {
                    closePanel();
                }
                if (!e.target.closest('.panel-nav')) {
                    closeAllSubmenus();
                }
            });

            // ESC closes
            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape') {
                    closePanel();
                    closeAllSubmenus();
                }
            });
        })();

        /* ===========================
           ACCOUNT DOTS MENU (⋮)
           =========================== */
        (function(){
            // close open dot menu when clicking elsewhere
            document.addEventListener('click', function(e) {
                const open = document.querySelector('.dots-menu:not([hidden])');
                if (open && !open.contains(e.target) && !e.target.closest('.dots-btn')) {
                    open.hidden = true;
                    const btn = document.querySelector('.dots-btn[aria-expanded="true"]');
                    if (btn) btn.setAttribute('aria-expanded', 'false');
                }
            });

            // open / close via ⋮ button
            document.addEventListener('click', function(e) {
                const btn = e.target.closest('.dots-btn');
                if (!btn) return;

                e.preventDefault();
                e.stopPropagation();

                const wrapper = btn.closest('.acct-actions');
                if (!wrapper) return;

                const menu = wrapper.querySelector('.dots-menu');
                if (!menu) return;

                // close others
                document.querySelectorAll('.dots-menu').forEach(m => {
                    if (m !== menu) m.hidden = true;
                });
                document.querySelectorAll('.dots-btn').forEach(b => {
                    if (b !== btn) b.setAttribute('aria-expanded','false');
                });

                const isOpen = !menu.hasAttribute('hidden');
                if (isOpen) {
                    menu.hidden = true;
                    btn.setAttribute('aria-expanded','false');
                } else {
                    menu.hidden = false;
                    btn.setAttribute('aria-expanded','true');
                    const first = menu.querySelector('[role="menuitem"]');
                    if (first) first.focus();
                }
            });

            // ESC closes current dots menu
            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape') {
                    const open = document.querySelector('.dots-menu:not([hidden])');
                    if (open) {
                        open.hidden = true;
                        const btn = document.querySelector('.dots-btn[aria-expanded="true"]');
                        if (btn) {
                            btn.setAttribute('aria-expanded', 'false');
                            btn.focus();
                        }
                    }
                }

                const active = document.activeElement;
                if (active && active.closest && active.closest('.dots-menu')) {
                    const items = Array.from(active.closest('.dots-menu').querySelectorAll('[role="menuitem"]'));
                    const idx = items.indexOf(active);
                    if (e.key === 'ArrowDown') {
                        e.preventDefault();
                        const next = items[(idx + 1) % items.length];
                        if (next) next.focus();
                    } else if (e.key === 'ArrowUp') {
                        e.preventDefault();
                        const prev = items[(idx - 1 + items.length) % items.length];
                        if (prev) prev.focus();
                    }
                }
            });

            // demo action router
            document.addEventListener('click', function(e) {
                const item = e.target.closest('.dots-menu-item');
                if (!item) return;
                e.preventDefault();

                const action = item.textContent.trim();
                const row = item.closest('tr');
                let accountNumber = null;
                if (row) {
                    const acctCell = row.querySelector('.acct-number');
                    if (acctCell) accountNumber = acctCell.textContent.trim();
                }

                console.log('Menu action:', action, 'account:', accountNumber);

                const menu = item.closest('.dots-menu');
                if (menu) {
                    menu.hidden = true;
                    const btn = menu.parentElement.querySelector('.dots-btn');
                    if (btn) {
                        btn.setAttribute('aria-expanded','false');
                        btn.focus();
                    }
                }
            });
        })();

        /* ===========================
           MAIN VIEW CONTROLLER
           Dashboard / Withdraw /
           Account list / Internal transfer
           =========================== */
        document.addEventListener('DOMContentLoaded', function () {
            const balanceArea          = document.getElementById('balance-area')  || document.querySelector('.balance-card');
            const accountsArea         = document.getElementById('accounts-area') || document.querySelector('.accounts-panel');
            const withdrawArea         = document.getElementById('withdraw-area');
            const accountListArea      = document.getElementById('accountlist-area');
            const internalTransferArea = document.getElementById('internal-transfer-area');
            const rightPanel           = document.getElementById('rightPanel');
            const profileArea          = document.getElementById('profile-area');
            const profileBackBtn       = document.getElementById('profileBackBtn');

            const withdrawBackBtn      = document.getElementById('withdrawBackBtn');
            const accountListBackBtn   = document.getElementById('accountListBackBtn');
            const internalBackBtn      = document.getElementById('internalBackBtn');

            function closeRightPanel() {
                if (!rightPanel) return;
                rightPanel.classList.remove('open');
                rightPanel.setAttribute('aria-hidden', 'true');
            }

            function showView(view) {
                const showDashboard   = (view === 'dashboard');
                const showWithdraw    = (view === 'withdraw');
                const showAccountList = (view === 'accountlist');
                const showInternal    = (view === 'internal');
                const showProfile     = (view === 'profile');

                if (balanceArea) {
                    balanceArea.style.display = showDashboard ? 'block' : 'none';
                    balanceArea.classList.remove('hidden');
                }
                if (accountsArea) {
                    accountsArea.style.display = showDashboard ? 'block' : 'none';
                    accountsArea.classList.remove('hidden');
                }
                if (withdrawArea)         withdrawArea.style.display         = showWithdraw    ? 'block' : 'none';
                if (accountListArea)      accountListArea.style.display      = showAccountList ? 'block' : 'none';
                if (internalTransferArea) internalTransferArea.style.display = showInternal    ? 'block' : 'none';
                if (profileArea)          profileArea.style.display          = showProfile     ? 'block' : 'none';

                closeRightPanel();
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }

            // Back buttons -> Dashboard
            if (withdrawBackBtn) {
                withdrawBackBtn.addEventListener('click', function(e){
                    e.preventDefault();
                    showView('dashboard');
                });
            }
            if (accountListBackBtn) {
                accountListBackBtn.addEventListener('click', function(e){
                    e.preventDefault();
                    showView('dashboard');
                });
            }
            if (internalBackBtn) {
                internalBackBtn.addEventListener('click', function(e){
                    e.preventDefault();
                    showView('dashboard');
                });
            }
            if (rightPanel) {
            rightPanel.classList.remove('open');
            rightPanel.setAttribute('aria-hidden','true');
        }
        window.scrollTo({ top: 0, behavior: 'smooth' });
            if (profileBackBtn) {
            profileBackBtn.addEventListener('click', function (e) {
                e.preventDefault();
                showView('dashboard');
            });
        }

            // Tabs in account list (REAL / DEMO / CLOSED)
            const tabButtons = document.querySelectorAll('.acct-tab');
            const rows       = document.querySelectorAll('#accounts-body tr');

            function setActiveTab(tab) {
                tabButtons.forEach(btn => {
                    const isActive = btn.dataset.tab === tab;
                    btn.classList.toggle('active', isActive);
                    btn.style.color = isActive ? '#111827' : '#6b7280';
                    btn.style.fontWeight = isActive ? '600' : '500';
                });

                rows.forEach(r => {
                    const cat = r.dataset.cat || 'real';
                    r.style.display = (cat === tab) ? 'table-row' : 'none';
                });
            }

            tabButtons.forEach(btn => {
                btn.addEventListener('click', function () {
                    setActiveTab(this.dataset.tab);
                });
            });

            if (tabButtons.length) {
                setActiveTab('real');
            }

            // Hook links: Dashboard / Withdraw / Account list / Internal transfer
            const allLinks = Array.from(document.querySelectorAll('a'));
            allLinks.forEach(a => {
                const text = (a.textContent || '').trim().toLowerCase();
                const href = (a.getAttribute('href') || '').toLowerCase();

                // Dashboard
                if (text === 'dashboard' || href === '#dashboard') {
                    a.addEventListener('click', function (e) {
                        e.preventDefault();
                        showView('dashboard');
                    });
                }

                // Withdraw
                if (text === 'withdraw' || href === '#withdraw') {
                    a.addEventListener('click', function (e) {
                        e.preventDefault();
                        showView('withdraw');
                    });
                }

                // Account list
                if (text === 'account list' || href === '#account-list') {
                    a.addEventListener('click', function (e) {
                        e.preventDefault();
                        showView('accountlist');
                    });
                }

                // Internal transfer
                if (text === 'internal transfer' || href === '#internal-transfer') {
                    a.addEventListener('click', function (e) {
                        e.preventDefault();
                        showView('internal');
                    });
                }
                if (href === '#profile' || a.classList.contains('profile-link')) { // 👈 NEW
                    a.addEventListener('click', function (e) {
                        e.preventDefault();
                        showView('profile');
                    });
                }
            });

            // Default view: dashboard
            showView('dashboard');
        });

        /* ===========================
           SMALL KEBAB MENUS (if used)
           =========================== */
        (function () {
            document.addEventListener('DOMContentLoaded', function () {
                const kebabButtons = document.querySelectorAll('.kebab-btn');

                function closeAllKebabs() {
                    document.querySelectorAll('.kebab-menu').forEach(m => {
                        m.hidden = true;
                    });
                    kebabButtons.forEach(b => b.setAttribute('aria-expanded', 'false'));
                }

                kebabButtons.forEach(btn => {
                    const menu = btn.parentElement.querySelector('.kebab-menu');
                    if (!menu) return;

                    btn.addEventListener('click', function (e) {
                        e.stopPropagation();
                        const isOpen = !menu.hidden;
                        closeAllKebabs();
                        if (!isOpen) {
                            menu.hidden = false;
                            btn.setAttribute('aria-expanded', 'true');
                        }
                    });
                });

                document.addEventListener('click', function () {
                    closeAllKebabs();
                });

                document.addEventListener('keydown', function (e) {
                    if (e.key === 'Escape') {
                        closeAllKebabs();
                    }
                });
            });
        })();

        /* ===========================
           AVATAR DROPDOWN (user card)
           =========================== */
        (function () {
            const avatar   = document.getElementById('avatarToggle');
            const dropdown = document.getElementById('userDropdown');

            if (!avatar || !dropdown) return;

            function openDropdown() {
                dropdown.hidden = false;
                avatar.setAttribute('aria-expanded', 'true');
            }

            function closeDropdown() {
                dropdown.hidden = true;
                avatar.setAttribute('aria-expanded', 'false');
            }

            function toggleDropdown() {
                if (dropdown.hidden) openDropdown(); else closeDropdown();
            }

            avatar.addEventListener('click', function (e) {
                e.stopPropagation();
                toggleDropdown();
            });

            // click outside closes
            document.addEventListener('click', function (e) {
                if (!dropdown.hidden &&
                    !dropdown.contains(e.target) &&
                    !avatar.contains(e.target)) {
                    closeDropdown();
                }
            });

            // ESC closes
            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') closeDropdown();
            });
        })();
    </script>
</body>
</html>
