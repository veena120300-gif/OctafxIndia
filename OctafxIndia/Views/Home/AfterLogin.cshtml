    @{
        // classify accounts into REAL / DEMO / CLOSED for counts
        var realAccounts = Model.Accounts
        .Where(a => (a.AccountType ?? "").ToUpper() == "REAL" &&
        !((a.Status ?? "").ToLower().Contains("deactivated") ||
        (a.Status ?? "").ToLower().Contains("closed")))
        .ToList();

        var demoAccounts = Model.Accounts
        .Where(a => (a.AccountType ?? "").ToUpper() == "DEMO" &&
        !((a.Status ?? "").ToLower().Contains("deactivated") ||
        (a.Status ?? "").ToLower().Contains("closed")))
        .ToList();

        var closedAccounts = Model.Accounts
        .Where(a => (a.Status ?? "").ToLower().Contains("deactivated") ||
        (a.Status ?? "").ToLower().Contains("closed"))
        .ToList();

        // order: REAL, DEMO, CLOSED (for rendering)
        var orderedAccounts = realAccounts
        .Concat(demoAccounts)
        .Concat(closedAccounts)
        .ToList();
    }
