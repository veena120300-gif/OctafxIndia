@model OctafxIndia.ViewModels.BalanceViewModel

@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Octa</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/css/AfterLogin.css" />
    <link rel="icon" type="image/x-icon" href="~/Images/logo.jpg" />

    <style>
        :root {
            --bg: #f3f6fb;
            --card-bg: #fff;
            --muted: #6b7280;
            --accent: #1446ff;
            --row-border: rgba(18,35,75,0.06);
            --pill-bg: #f3f6fb;
            --pill-text: #1344ff;
            --table-radius: 16px;
        }

        .trading-wrap {
            position: relative;
            display: inline-block; /* so hover works nicely */
        }

        /* hidden by default */
        .trading-dropdown {
            display: none;
            position: absolute;
            top: 48px;
            left: 0;
            width: 260px;
            background: #ffffff;
            border-radius: 18px;
            padding: 16px 0;
            box-shadow: 0px 14px 40px rgba(15, 23, 42, 0.22);
            border: 1px solid rgba(148, 163, 184, 0.25);
            z-index: 1200;
        }

        /* show on hover */
        .trading-wrap:hover .trading-dropdown {
            display: block;
        }

        .trading-dropdown .dd-link {
            display: block;
            padding: 10px 20px;
            font-size: 15px;
            text-decoration: none;
            color: #1f2937;
        }

            .trading-dropdown .dd-link:hover {
                background: #f3f4f6;
            }

        /* optional: highlight Trading tab while open */
        .trading-wrap:hover .trading-btn {
            background: #f3f4f6;
            border-radius: 8px;
        }

        /* Avatar dropdown */
        .topbar-right {
            position: relative;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .user-dropdown {
            position: absolute;
            top: 52px; /* just under the header */
            right: 0;
            width: 260px;
            background: #ffffff;
            border-radius: 18px;
            box-shadow: 0 18px 45px rgba(15,23,42,0.16);
            padding: 14px 16px;
            border: 1px solid rgba(148,163,184,0.35);
            z-index: 1400;
        }

            .user-dropdown[hidden] {
                display: none;
            }

        .user-dropdown-header {
            margin-bottom: 10px;
        }

        .user-dropdown-name {
            font-weight: 700;
            font-size: 15px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .user-dropdown-email {
            font-size: 13px;
            color: #6b7280;
        }

        .user-dropdown-list {
            margin-top: 8px;
        }

        .user-item {
            font-size: 14px;
            padding: 7px 0;
            display: flex;
            align-items: center;
            justify-content: space-between;
            cursor: pointer;
        }

            .user-item:hover {
                color: #111827;
            }

        .user-badge {
            font-size: 11px;
            padding: 1px 6px;
            border-radius: 999px;
            background: #fef3c7;
            color: #92400e;
            margin-left: 8px;
        }

        .user-lang-pill {
            font-size: 11px;
            padding: 2px 8px;
            border-radius: 999px;
            background: #eef2ff;
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }

            .user-lang-pill span {
                font-size: 12px;
            }


        body {
            font-family: Inter, system-ui, Arial, sans-serif;
            margin: 0;
            background: var(--bg);
            color: #111;
        }

        .page-wrap {
            padding: 40px 24px;
            display: flex;
            justify-content: center;
        }

        /* balance card (kept simple) */
        .balance-card {
            width: 820px;
            max-width: 95%;
            background: var(--card-bg);
            border-radius: 20px;
            padding: 36px;
            box-shadow: 0 6px 20px rgba(18,35,75,0.06);
            margin-bottom: 28px;
            margin-top: 107px;
            margin-left: 91px;
        }

        /* === Accounts card (new styling to match screenshot 1) === */
        .accounts-panel {
            width: 920px;
            max-width: 95%;
            margin: 0 auto;
        }

        .accounts-card {
            background: var(--card-bg);
            border-radius: 20px;
            padding: 28px;
            box-shadow: 0 6px 24px rgba(18,35,75,0.04);
            overflow: hidden;
        }

        .accounts-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 18px;
        }

            .accounts-header h3 {
                margin: 0;
                font-size: 20px;
                font-weight: 700;
            }

        .create-account-link {
            color: var(--accent);
            font-weight: 700;
            text-decoration: none;
            letter-spacing: 0.6px;
        }

        .account-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 15px;
        }

            .account-table thead th {
                text-align: left;
                padding: 14px 12px;
                color: #6b7280;
                font-weight: 600;
                border-bottom: 1px solid rgba(18,35,75,0.04);
            }

            .account-table tbody tr {
                border-bottom: 1px solid var(--row-border);
            }

            .account-table td {
                padding: 18px 12px;
                vertical-align: middle;
            }

        /* left column: icon + dots + account number */
        .account-left {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .acct-icon {
            width: 36px;
            height: 36px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 6px;
        }

            .acct-icon img {
                max-width: 100%;
                max-height: 100%;
                display: block;
            }

        .vertical-dots {
            width: 18px;
            height: 18px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: var(--muted);
            font-size: 18px;
            margin-right: 6px;
        }

        .acct-number {
            font-weight: 600;
            letter-spacing: 0.2px;
        }

        /* type pill */
        .type-pill {
            display: inline-block;
            padding: 6px 10px;
            border-radius: 12px;
            background: var(--pill-bg);
            color: var(--pill-text);
            font-weight: 700;
            font-size: 13px;
            box-shadow: 0 0 0 6px rgba(19,68,255,0.03) inset;
        }

        /* server */
        .server-col {
            color: #111;
        }

        /* right columns */
        .balance-col, .equity-col {
            font-weight: 700;
        }

        .status-col {
            color: var(--muted);
            font-size: 14px;
            text-align: right;
            padding-right: 6px;
        }

        /* remove last row border */
        .account-table tbody tr:last-child {
            border-bottom: none;
        }

        /* hover effect */
        .account-table tbody tr:hover {
            background: linear-gradient(90deg, rgba(20,70,255,0.02), rgba(20,70,255,0.01));
        }

        /* small device adjustments */
        @@media (max-width: 880px) {
            .accounts-card {
                padding: 18px;
            }

            .account-table thead {
                display: none;
            }

            .account-table tbody td {
                display: block;
                padding: 12px;
            }

            .account-table tbody tr {
                margin-bottom: 12px;
                display: block;
                border-bottom: none;
                background: transparent;
            }

            .status-col {
                text-align: left;
                padding-top: 6px;
            }
        }
        /* dropdown menu for vertical-dots */
        .acct-actions {
            position: relative;
            display: inline-block;
        }

        .dots-btn {
            background: transparent;
            border: 0;
            padding: 6px;
            font-size: 18px;
            line-height: 1;
            color: var(--muted, #6b7280);
            cursor: pointer;
            border-radius: 6px;
        }

            .dots-btn:focus {
                outline: 2px solid rgba(20,68,255,0.14);
                outline-offset: 2px;
            }

        /* visually small dot glyph */
        .dots-visual {
            display: inline-block;
            font-size: 18px;
            transform: translateY(-1px);
        }

        /* the popup menu */
        .dots-menu {
            position: absolute;
            right: -197px; /* align under button */
            top: calc(100% + 8px);
            min-width: 220px;
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(2,6,23,0.08);
            padding: 8px 0;
            z-index: 1200;
            border: 1px solid rgba(18,35,75,0.05);
        }

            /* hidden state (use hidden attr as default) */
            .dots-menu[hidden] {
                display: none;
            }

        /* menu items */
        .dots-menu-item {
            display: block;
            padding: 12px 16px;
            color: var(--accent, #1446ff);
            text-decoration: none;
            font-weight: 600;
            transition: background .12s ease;
        }

            .dots-menu-item:hover,
            .dots-menu-item:focus {
                background: rgba(20,68,255,0.03);
                outline: none;
            }

        .actions {
            margin-top: 28px;
            display: flex;
            gap: 18px;
            align-items: center;
        }

        .btn {
            padding: 10px 22px;
            border-radius: 40px;
            text-decoration: none;
            display: inline-block;
            font-weight: 600;
        }

        .btn-primary {
            background: #1344ff;
            color: #fff;
        }

        .btn-outline {
            background: #f3f6ff;
            color: #1344ff;
            border: 0;
        }
        /* put this into AfterLogin.css or inside a <style> block */
        .payment-option {
            background: white;
            border: 1px solid #e5e7eb;
            border-radius: 14px;
            padding: 16px;
            font-size: 16px;
            display: flex;
            align-items: center;
            cursor: pointer;
            transition: all .15s ease;
        }

            .payment-option:hover {
                border-color: #2563eb;
                box-shadow: 0 6px 18px rgba(37,99,235,0.08);
            }

        .hidden {
            display: none !important;
        }
        /* Account list layout */
        .accounts-page {
            max-width: 960px;
            margin: 40px auto;
        }

        .accounts-card {
            background: #ffffff;
            border-radius: 20px;
            padding: 24px 24px 28px 24px;
            box-shadow: 0 10px 30px rgba(15, 23, 42, 0.06);
        }

        .accounts-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 16px;
        }

            .accounts-header h2 {
                margin: 0;
                font-size: 24px;
                font-weight: 700;
            }

            .accounts-header p {
                margin: 6px 0 0 0;
                font-size: 14px;
                color: #6b7280;
            }

            .accounts-header a {
                color: #2563eb;
                text-decoration: none;
            }

                .accounts-header a:hover {
                    text-decoration: underline;
                }

        /* Tabs */
        .accounts-tabs {
            display: flex;
            gap: 24px;
            margin-top: 20px;
            border-bottom: 1px solid #e5e7eb;
        }

        .acct-tab {
            border: none;
            background: none;
            font-size: 14px;
            font-weight: 500;
            padding: 0 0 10px;
            cursor: pointer;
            color: #6b7280;
            position: relative;
        }

            .acct-tab.active {
                color: #111827;
                font-weight: 600;
            }

                .acct-tab.active::after {
                    content: "";
                    position: absolute;
                    left: 0;
                    right: 0;
                    bottom: -1px;
                    height: 2px;
                    background: #2563eb;
                }

        .tab-pill {
            display: inline-block;
            margin-left: 6px;
            padding: 0 6px;
            font-size: 11px;
            border-radius: 999px;
            background: #e5edff;
            color: #2563eb;
        }

        /* Table */
        .accounts-table-wrap {
            margin-top: 16px;
            overflow-x: auto;
        }

        .accounts-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 14px;
            margin-bottom: 66px;
        }

            .accounts-table thead tr {
                color: #6b7280;
                text-align: left;
            }

            .accounts-table th,
            .accounts-table td {
                padding: 12px 6px;
                border-bottom: 1px solid #f3f4f6;
            }

        /* First column layout */
        .acct-col-account {
            min-width: 220px;
        }

        .acct-account-line {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .acct-platform {
            font-size: 14px;
            font-weight: 700;
            color: #111827;
            margin-right: 4px;
        }

            .acct-platform span {
                color: #f97316; /* orange 4/5 */
            }

        .acct-number {
            font-size: 14px;
            color: #111827;
        }

        /* Type pill (REAL/DEMO) */
        .acct-type-pill {
            display: inline-flex;
            align-items: center;
            padding: 3px 10px;
            font-size: 11px;
            border-radius: 999px;
            background: #2563eb;
            color: #ffffff;
            font-weight: 600;
        }

        /* three vertical dots */
        .acct-kebab {
            margin-left: auto;
            position: relative;
        }

        .kebab-btn {
            width: 24px;
            height: 24px;
            border-radius: 999px;
            border: none;
            background: transparent;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
        }

            .kebab-btn span {
                display: block;
                width: 3px;
                height: 3px;
                border-radius: 999px;
                background: #9ca3af;
                margin: 1px 0;
            }

        /* dropdown menu under the 3 dots */
        .kebab-menu {
            position: absolute;
            right: 0;
            top: 26px;
            min-width: 180px;
            background: white;
            border-radius: 12px;
            box-shadow: 0 12px 30px rgba(15, 23, 42, 0.12);
            padding: 6px 0;
            z-index: 20;
        }

            .kebab-menu button {
                width: 100%;
                padding: 8px 14px;
                border: none;
                background: transparent;
                font-size: 13px;
                text-align: left;
                cursor: pointer;
                color: #111827;
            }

                .kebab-menu button:hover {
                    background: #f3f4ff;
                }

        /* simple outline button for Back */
        .btn-outline-light {
            border-radius: 8px;
            border: 1px solid #e5e7eb;
            padding: 6px 12px;
            font-size: 13px;
            background: #fff;
            cursor: pointer;
        }

            .btn-outline-light:hover {
                background: #f9fafb;
            }

        .accounts-bottom {
            margin-top: 26px;
            display: flex;
            justify-content: center;
        }

        .btn-open-real {
            min-width: 260px;
            padding: 14px 32px;
            border-radius: 999px;
            border: none;
            background: #2563ff;
            background: linear-gradient(90deg, #2563ff, #3155ff);
            color: #ffffff;
            font-size: 14px;
            font-weight: 600;
            letter-spacing: 0.06em;
            text-transform: uppercase;
            cursor: pointer;
            box-shadow: 0 14px 35px rgba(37, 99, 235, 0.35);
            transition: transform 0.12s ease, box-shadow 0.12s ease, opacity 0.12s ease;
        }

            .btn-open-real:hover {
                transform: translateY(-1px);
                box-shadow: 0 18px 40px rgba(37, 99, 235, 0.45);
                opacity: 0.96;
            }

            .btn-open-real:active {
                transform: translateY(0);
                box-shadow: 0 10px 24px rgba(37, 99, 235, 0.35);
            }
    </style>
</head>
<body>
    <!-- Top header -->
    <div class="topbar-wrapper">
        <header class="topbar" role="banner">
            <div class="logo">
                <img class="mark" src="/Images/logo.jpg" alt="Octa Logo" style="height:28px;" />
                <div style="font-weight:800">Octa</div>
            </div>

            <nav class="topbar-nav" aria-label="Main navigation">
                <a href="#dashboard" class="nav-item">Dashboard</a>

                <div class="nav-item trading-wrap">
                    <a href="#trading" class="nav-item trading-btn">Trading</a>

                    <!-- Dropdown attached to Trading -->
                    <div class="trading-dropdown">
                        <a href="#" class="dd-link">Trade in web</a>
                        <a href="#" class="dd-link">Download desktop MT4</a>
                        <a href="#" class="dd-link">Download MT4 for Android</a>
                    </div>
                </div>

                <div class="nav-item trading-wrap">
                    <a href="#ibarea" class="nav-item trading-btn">IB Area</a>

                    <!-- Dropdown attached to Trading -->
                    <div class="trading-dropdown">
                        <a href="#" class="dd-link">IB Dashboard</a>
                        <a href="#" class="dd-link">Revenue Statistics</a>
                        <a href="#" class="dd-link">Promo Materials</a>
                        <a href="#" class="dd-link">FAQ</a>
                    </div>
                </div>
                <div class="nav-item trading-wrap">
                    <a href="#bonuses" class="nav-item trading-btn">Bonuses</a>

                    <!-- Dropdown attached to Trading -->
                    <div class="trading-dropdown">
                        <a href="#" class="dd-link">Available</a>
                        <a href="#" class="dd-link">Active and Cancelled</a>
                        <a href="#" class="dd-link">Auto-apply setting</a>
                        <a href="#" class="dd-link">Detailed Information</a>
                    </div>
                </div>
                <a href="#rewards" class="nav-item">Octa Rewards</a>
            </nav>

            <div class="topbar-right">
                <button class="btn deposit" style="background:#1446ff;color:#fff;border-radius:8px;padding:8px 12px;border:0;">Deposit</button>

                <div class="avatar-wrap" id="avatarToggle" aria-haspopup="true" aria-expanded="false">
                    <img class="avatar" src="/Images/user-avatar.png" alt="User avatar" style="height:34px;border-radius:50%;" />
                </div>

                <div id="userDropdown" class="user-dropdown" role="menu" hidden>
                    <div class="user-dropdown-header">
                        <div class="user-dropdown-name">
                            <span>@User.Identity.Name</span>
                            <span>›</span>
                        </div>
                        <div class="user-dropdown-email">
                            <a href="#profile"
                               class="profile-link"
                               style="text-decoration:none;color:inherit;">
                                @User.Identity.Name
                            </a>
                        </div>
                    </div>

                    <div class="user-dropdown-list">
                        <div class="user-item"><span>Notifications</span></div>
                        <div class="user-item">Newsletters</div>
                        <div class="user-item">Bonus settings</div>
                        <div class="user-item">Account log</div>
                        <div class="user-item">Change passwords</div>
                        <div class="user-item">
                            <span>Language</span>
                            <span class="user-lang-pill">
                                <span>🌐</span><span>En</span>
                            </span>
                        </div>
                        <div class="user-item">Log out</div>
                    </div>
                </div>

                <button id="menuToggle" class="menu-btn" aria-label="Open menu" aria-haspopup="true" aria-expanded="false" style="background:transparent;border:0;font-size:20px;">☰</button>
            </div>
        </header>
    </div>

    <!-- Page content -->
    <div class="page-wrap">
        <div style="max-width:1000px; width:100%;">
            <!-- Balance card (kept minimal here) -->
            <div id="balance-area" class="balance-card" role="region" aria-label="Balance">
                <div style="display:flex; justify-content:space-between; align-items:flex-start;">
                    <div>
                        <div style="font-size:13px;color:#9aa3b2;">Balance</div>
                        <div style="font-size:40px;font-weight:700;margin-top:6px;">@Model.Balance.ToString("C")</div>
                    </div>
                    <div style="text-align:right;">
                        <div style="background:var(--accent); color:#fff; font-size:12px; padding:6px 12px; border-radius:12px; display:inline-block;">@Model.AccountType</div>
                        <div style="font-size:12px;color:#6b7280;margin-top:8px;">@Model.AccountNumber</div>
                    </div>
                </div>
                <div style="margin-top:24px; display:flex; gap:24px; flex-wrap:wrap;">
                    <div style="min-width:120px;">
                        <div style="color:#8b95a6; font-size:13px;">Free margin</div>
                        <div style="font-weight:700; margin-top:6px;">@Model.FreeMargin.ToString("C")</div>
                    </div>
                    <div style="min-width:120px;">
                        <div style="color:#8b95a6; font-size:13px;">Equity</div>
                        <div style="font-weight:700; margin-top:6px;">@Model.Equity.ToString("C")</div>
                    </div>
                    <div style="min-width:120px;">
                        <div style="color:#8b95a6; font-size:13px;">Leverage</div>
                        <div style="font-weight:700; margin-top:6px;">@Model.Leverage</div>
                    </div>
                    <div style="min-width:120px;">
                        <div style="color:#8b95a6; font-size:13px;">Server</div>
                        <div style="font-weight:700; margin-top:6px;">@Model.Server</div>
                    </div>
                    <div style="min-width:120px;">
                        <div style="color:#8b95a6; font-size:13px;">No swap</div>
                        <div style="font-weight:700; margin-top:6px;">@((Model.NoSwap) ? "Yes" : "No")</div>
                    </div>
                </div>
                <!-- Buttons -->
                <div class="actions">
                    <a class="btn btn-outline-primary btn-lg" href="#">TRADE</a>
                    <a class="btn btn-primary btn-lg btn-primary-round" href="#">DEPOSIT</a>
                    <a class="btn btn-outline-primary btn-lg" href="#">WITHDRAW</a>
                </div>

                <!-- Link -->
                <div style="margin-top:18px; font-size:14px;">
                    <a href="#">Forgot trading account password?</a>
                </div>
            </div>

            <!-- === Accounts card (styled like screenshot 1) === -->
            <div id="accounts-area" class="accounts-panel" aria-label="Your accounts">
                <div class="accounts-card">
                    <div class="accounts-header">
                        <h3>Your accounts</h3>
                        <a href="#" class="create-account-link">CREATE ACCOUNT</a>
                    </div>

                    <table class="account-table" role="table" aria-label="Accounts table">
                        <thead>
                            <tr>
                                <th>Account</th>
                                <th>Type</th>
                                <th>Server</th>
                                <th>Balance</th>
                                <th>Equity</th>
                                <th style="text-align:right;padding-right:12px;">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model?.Accounts == null || !Model.Accounts.Any())
                            {
                                <tr>
                                    <td colspan="6" style="padding:18px 12px; color:#6b7280;">No trading accounts found.</td>
                                </tr>
                            }
                            else
                            {
                                foreach (var acct in Model.Accounts)
                                {
                                    <tr>
                                        <td>
                                            <div class="account-left">
                                                <div class="acct-icon" title="@acct.AccountType">
                                                    @{
                                                        // pick icon based on account type or use fallback
