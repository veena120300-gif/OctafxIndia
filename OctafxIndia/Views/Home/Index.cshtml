<!-- INSTALL THE APP SECTION -->
<section id="install-app" class="install-app-section" aria-label="Install the app">
    <div class="install-app-container">

        <!-- LEFT TEXT -->
        <div class="install-buttons">
            <h2 class="install-app-title">Get yourself an extra source of income</h2>
            <p class="install-app-sub">Discover global markets with an easy-to-use app.</p>

            <div class="store-buttons-row">

                <a class="store-btn-wrapper" href="https://play.google.com/">
                    <img src="/Images/google-play-logo.svg" alt="Google Play" class="store-logo">
                    <div class="store-text">
                        <span>Get it on</span><br>
                        <b>Google Play</b>
                    </div>
                </a>

                <a class="store-btn-wrapper" href="#">
                    <img src="/Images/ios-logo.svg" alt="App Store" class="store-logo">
                    <div class="store-text">
                        <span>Download on the</span><br>
                        <b>App Store</b>
                    </div>
                </a>

            </div>
        </div>


        <!-- RIGHT PHONE + QR -->
        <div class="install-app-right" aria-hidden="false">
            <div class="phone-wrapper" role="img" aria-label="Mobile app preview">
                <!-- Using uploaded local image so result matches your asset exactly -->
                <img src="~/Images/mobile-app.jpg" class="phone-img" alt="Mobile App" />

                <!-- QR overlay (use your qr file path if different) -->
                <!-- If your QR is at /Images/qr.png keep it; if you uploaded to /mnt/data use that path -->
                <img src="/Images/qr.png" class="qr-img" alt="QR Code" />
            </div>
        </div>

    </div>
</section>

<script>
    document.querySelectorAll('.accordion-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const item = btn.closest('.accordion-item');
        const panel = item.querySelector('.accordion-panel');
        const isOpen = item.classList.contains('open');

        // Close all items
        document.querySelectorAll('.accordion-item').forEach(i => {
          i.classList.remove('open');
          i.querySelector('.accordion-panel').hidden = true;
          i.querySelector('.accordion-btn').setAttribute('aria-expanded', 'false');
        });

        // Toggle current
        if (!isOpen) {
          item.classList.add('open');
          panel.hidden = false;
          btn.setAttribute('aria-expanded', 'true');
        }
      });
    });
</script>
