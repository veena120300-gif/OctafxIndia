                </div>
            </div>

            <div class="accordion-item">
                <button class="accordion-btn" aria-expanded="false" aria-controls="acc-panel-4" id="acc-btn-4">
                    <span class="accordion-title">Live trading sessions</span>
                    <span class="accordion-indicator" aria-hidden="true">▾</span>
                </button>
                <div id="acc-panel-4" class="accordion-panel" role="region" aria-labelledby="acc-btn-4" hidden>
                    <p>Watch experts trade live and copy their secrets. Live explanation and opportunity to ask questions.</p>
                </div>
            </div>
        </div>

        <div class="cta" style="text-align:center; margin-top:36px;">
            <a href="/Account/Register" class="hero-btn">CREATE AN ACCOUNT</a>
        </div>
    </div>
</section>

