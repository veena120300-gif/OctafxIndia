@model OctafxIndia.Models.LoginViewModel
@using (Html.BeginForm("Login", "Account", FormMethod.Post, new { id = "loginForm", @class = "login-form" }))
{
    @Html.AntiForgeryToken()

    <div id="loginOverlay" class="login-overlay" aria-hidden="true"></div>

    <aside id="loginPanel" class="login-panel" role="dialog" aria-hidden="true" aria-labelledby="loginTitle">
        <button type="button" id="closeLoginBtn" class="login-close" aria-label="Close">×</button>

        <div class="login-panel-inner">
            <div class="login-brand">
                <img src="~/Images/logo.jpeg" alt="Logo" style="height:36px" />
            </div>

            <h2 id="loginTitle">Log in to Octa</h2>

            <div class="form-group">
                @Html.LabelFor(m => m.Email, new { @class = "sr-only" })
                @Html.TextBoxFor(m => m.Email, new { @class = "input", placeholder = "Email", autocomplete = "username" })
                @Html.ValidationMessageFor(m => m.Email)
            </div>

            <div class="form-group">
                @Html.LabelFor(m => m.Password, new { @class = "sr-only" })
                @Html.PasswordFor(m => m.Password, new { @class = "input", placeholder = "Password", autocomplete = "current-password" })
                @Html.ValidationMessageFor(m => m.Password)
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Log in</button>
            </div>

            <div class="divider"><span>other methods</span></div>

            <div class="socials">
                <button type="button" class="social-btn">f</button>
                <button type="button" class="social-btn"></button>
                <button type="button" class="social-btn">G</button>
            </div>

            <div class="signup-line">
                <span>Don't have an account? </span><a href="/Account/Register">Sign up</a>
            </div>
        </div>
    </aside>
}
