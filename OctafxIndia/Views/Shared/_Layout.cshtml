@* _Layout.cshtml *@
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Octa</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="icon" type="image/x-icon" href="~/Images/logo.jpg" />
</head>

<body>
    <!-- HEADER -->
    <header>
        <div class="logo">
            <img class="mark" src="/Images/logo.jpg" alt="Octa Logo" />
            <div><div style="font-weight:800">Octa</div></div>
        </div>

        <nav>
            <a href="#products">Trading</a>
            <a href="#platforms">Trading Platforms</a>
            <a href="#downloads">Referral programs</a>
            <a href="#education">Promotions</a>
            <a href="#contact">Analysis and education</a>

            <a href="#" class="copy-btn">
                Copy trading
                <span class="arrow"></span>
            </a>
        </nav>

        <div>
            <a href="#login" class="btn btn-light">Log in</a>
            <a asp-controller="Account" asp-action="Register" class="btn btn-primary">Sign up</a>
        </div>
        <div class="lang-dropdown-wrapper">
            <button id="langBtn" class="lang-btn">
                <img src="/Images/globe.svg" class="lang-icon" />
                En
            </button>

            <div id="langMenu" class="lang-menu">
                <h3>Language</h3>

                <ul>
                    <li class="active">English ✓</li>
                    <li>Bahasa Indonesia</li>
                    <li>中文</li>
                    <li>Bahasa Melayu</li>
                    <li>Português Brasileiro</li>
                    <li>Español</li>
                    <li>ภาษาไทย</li>
                    <li>Deutsch</li>
                    <li>বাংলা ভাষা</li>
                    <li>हिन्दी</li>
                    <li>اُردُو</li>
                    <li>Tiếng Việt</li>
                    <li>Türkçe</li>
                </ul>
            </div>
        </div>

    </header>

    <!-- MAIN CONTENT -->
    <main>
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="site-footer">
        <div class="footer-inner">
            <div class="footer-col">
                <h4 class="footer-col-title">Company</h4>
                <ul class="footer-links">
                    <li><a href="/about">About us</a></li>
                    <li><a href="/awards">Awards</a></li>
                    <li><a href="/ib-partner">IB partner program</a></li>
                    <li><a href="/contact">Contact us</a></li>
                    <li><a href="/legal">Legal documents</a></li>
                </ul>
            </div>

            <div class="footer-col">
                <h4 class="footer-col-title">Media</h4>
                <ul class="footer-links">
                    <li><a href="/news">Company news</a></li>
                    <li><a href="/reviews">Reviews</a></li>
                    <li><a href="/blog">Octa Blog</a></li>
                </ul>
            </div>

        </div>

        <div class="footer-bottom">
            <small>© <span id="year"></span> Your Company. All rights reserved.</small>
        </div>
    </footer>

    <script>
        // small helper to set copyright year
        (function(){ document.getElementById('year').textContent = new Date().getFullYear(); }());
    </script>


    <!-- ========================== -->
    <!-- LOGIN OVERLAY + PANEL -->
    <!-- ========================== -->

    <div id="loginOverlay" class="login-overlay" aria-hidden="true"></div>

    <aside id="loginPanel" class="login-panel" aria-hidden="true" role="dialog" aria-labelledby="loginTitle">

        <button type="button" id="closeLoginBtn" class="login-close" aria-label="Close">×</button>

        <div class="login-panel-inner">

            <div class="login-brand">
                <img src="/Images/logo.jpg" alt="Logo" style="height:36px; margin-bottom:10px;" />
            </div>

            <h2 id="loginTitle">Log in to Octa</h2>

            <form method="post" action="/Account/Login" id="loginForm" novalidate>
                @Html.AntiForgeryToken()

                <!-- EMAIL -->
                <div class="input-wrap">

                    <span class="icon-left">
                        <!-- Email SVG -->
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                             stroke="#999" stroke-width="1.6"
                             xmlns="http://www.w3.org/2000/svg">
                            <rect x="2" y="5" width="20" height="14" rx="2" />
                            <path d="M2 7l10 7 10-7" />
                        </svg>
                    </span>

                    <input id="emailInput" type="email" name="Email"
                           placeholder="Email" autocomplete="username"
                           required aria-label="Email" class="text-input" />

                    <button type="button" id="clearEmail" class="icon-right btn-clear"
                            aria-label="Clear email" title="Clear"></button>
                </div>


                <!-- PASSWORD -->
                <div class="input-wrap">

                    <span class="icon-left">
                        <!-- Lock SVG -->
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                             stroke="#999" stroke-width="1.6" stroke-linecap="round"
                             xmlns="http://www.w3.org/2000/svg">
                            <rect x="3" y="11" width="18" height="10" rx="2" />
                            <path d="M7 11V8a5 5 0 0110 0v3" />
                        </svg>
                    </span>

                    <input id="passwordInput" type="password" name="Password"
                           placeholder="Password" autocomplete="current-password"
                           required aria-label="Password" class="text-input" />

                    <button type="button" id="clearPassword" class="icon-right btn-clear"
                            aria-label="Clear password" title="Clear"></button>

                    <button type="button" id="togglePassword" class="icon-right btn-eye"
                            aria-label="Toggle password visibility" title="Show password">

                        <!-- EYE SHOW -->
                        <svg class="eye-show" width="20" height="20" viewBox="0 0 24 24" fill="none"
                             stroke="#666" stroke-width="1.6"
                             xmlns="http://www.w3.org/2000/svg">
                            <path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7S1 12 1 12z" />
                            <circle cx="12" cy="12" r="3" />
                        </svg>

                        <!-- EYE HIDE -->
                        <svg class="eye-hide" width="20" height="20" viewBox="0 0 24 24"
                             fill="none" stroke="#666" stroke-width="1.6"
                             xmlns="http://www.w3.org/2000/svg"
                             style="display:none">
                            <path d="M1 1l22 22" />
                            <path d="M3.5 8.8A10.4 10.4 0 019 4.2" />
                            <path d="M14.5 19.8A10.4 10.4 0 0111 20.8" />
                        </svg>

                    </button>
                </div>

                <a href="#" class="forgot-link">Forgot password</a>

                <button type="submit" class="btn btn-primary login-submit">Log in</button>
            </form>

            <div class="other-methods">
                <div class="divider"><span>other methods</span></div>

                <div class="socials">
                    <button type="button" class="social-btn social-fb" aria-label="Sign in with Facebook">
                        <!-- Facebook SVG -->
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg">
                            <path d="M22 12.07C22 6.48 17.52 2 11.93 2S1.86 6.48 1.86 12.07c0 4.9 3.44 8.98 8 9.78v-6.92H7.1v-2.86h2.76V9.34c0-2.73 1.63-4.24 4.12-4.24 1.2 0 2.46.22 2.46.22v2.7h-1.38c-1.36 0-1.78.84-1.78 1.71v2.02h3.03l-.48 2.86h-2.55V21.9c4.56-.8 8-4.88 8-9.83z" fill="#1877F2" />
                        </svg>
                    </button>

                    <button class="social-btn social-apple" aria-label="Login with Apple">
                        <img src="/Images/apple.svg" alt="Apple" class="social-icon">
                    </button>

                    <button type="button" class="social-btn social-google" aria-label="Sign in with Google">
                        <!-- Google SVG -->
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg">
                            <path d="M21.8 10.23h-9.1v3.52h5.22c-.23 1.22-1.37 3.58-5.22 3.58-3.14 0-5.7-2.6-5.7-5.8s2.56-5.8 5.7-5.8c1.79 0 3 .76 3.7 1.42l2.52-2.42C17.92 3.2 15.56 2 12.7 2 7.7 2 3.8 5.9 3.8 10.98s3.9 8.98 8.9 8.98c5.14 0 8.58-3.6 8.58-8.68 0-.58-.06-1.03-.48-1.05z" fill="#EA4335" />
                        </svg>
                    </button>
                </div>
            </div>


            <div class="signup-line">
                Don't have an account? <a href="/Account/Register">Sign up</a>
            </div>
        </div>
    </aside>

    <!-- Minimal CSS for modal (move into your CSS file) -->
    <style>
        .otp-modal {
            position: fixed;
            inset: 0;
            z-index: 2000;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .otp-modal-backdrop {
            position: absolute;
            inset: 0;
            background: rgba(0,0,0,0.45);
        }

        .otp-modal-panel {
            position: relative;
            width: 380px;
            max-width: 92%;
            background: #fff;
            padding: 24px;
            border-radius: 10px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.18);
            z-index: 2;
        }

        .otp-close {
            position: absolute;
            top: 8px;
            right: 8px;
            background: transparent;
            border: none;
            font-size: 20px;
            cursor: pointer;
        }

        #otpInput {
            width: 100%;
            margin: 12px 0;
            padding: 12px;
            border-radius: 8px;
            border: 1px solid #e6e6e6;
        }

        #otpTimerLabel {
            font-weight: 600;
        }

        .sr-only {
            position: absolute !important;
            width: 1px;
            height: 1px;
            padding: 0;
            margin: -1px;
            overflow: hidden;
            clip: rect(0,0,0,0);
            border: 0;
        }
    </style>


    <!-- ========================== -->
    <!-- FORGOT PASSWORD TEMPLATE -->
    <!-- ========================== -->

    <div id="forgotTemplate" style="display:none;">

        <div class="panel-top">
            <button type="button" class="back-btn" id="fpBackBtn" aria-label="Back">←</button>
            <button type="button" class="login-close" id="fpCloseBtn" aria-label="Close">×</button>
        </div>

        <div class="login-panel-inner fp-inner">

            <h2 class="fp-title">Reset password</h2>

            <p class="fp-desc">
                Enter the email address you used to register at Octa.
                We’ll send a link—use it to reset your password.
            </p>

            <form id="forgotForm" method="post" action="/Account/ForgotPassword">
                @Html.AntiForgeryToken()

                <div class="input-wrap">
                    <span class="icon-left">
                        <!-- Email SVG -->
                        <svg width="20" height="20" viewBox="0 0 24 24"
                             stroke="#999" stroke-width="1.6" fill="none"
                             xmlns="http://www.w3.org/2000/svg">
                            <rect x="2" y="5" width="20" height="14" rx="2" />
                            <path d="M2 7l10 7 10-7" />
                        </svg>
                    </span>

                    <input type="email" name="Email" placeholder="example@gmail.com"
                           autocomplete="email" required class="text-input" />
                </div>

                <button type="submit" class="btn btn-primary fp-send">Send link</button>

                <p class="recaptcha-note">
                    This site is protected by reCAPTCHA.
                    Google's <a href="#" target="_blank">Privacy Policy</a>
                    and <a href="#" target="_blank">Terms of Service</a> apply.
                </p>
            </form>
        </div>
    </div>



    <!-- SCRIPTS -->
    <script src="~/js/site.js"></script>

    @RenderSection("Scripts", required: false)
    <script>
    (function(){
      'use strict';
      console.log('[login-intercept] script loaded');

      document.addEventListener('DOMContentLoaded', function () {
        const form = document.getElementById('loginForm');
        if (!form) {
          console.warn('[login-intercept] #loginForm not found');
          return;
        }
        console.log('[login-intercept] found #loginForm');

        // If another script already attached a submit listener and prevented intercept,
        // we use capture phase to ensure we run first.
        form.addEventListener('submit', async function (ev) {
          console.log('[login-intercept] submit captured — preventing default');
          ev.preventDefault();
          ev.stopImmediatePropagation && ev.stopImmediatePropagation();

          // debug: show current form.action & method
          console.log('[login-intercept] form.action', form.action, 'method', form.method);

          const emailEl = document.getElementById('emailInput') || form.querySelector('input[name="Email"]');
          const email = emailEl ? (emailEl.value || '').trim() : null;
          if (!email) {
            console.warn('[login-intercept] email missing');
            showInline('Please enter your email address.');
            return;
          }

          // show inline error helper
          function showInline(msg){
            let container = document.querySelector('.login-panel-inner') || form;
            if (!container) { alert(msg); return; }
            let el = container.querySelector('.panel-error-inline');
            if (!el) {
              el = document.createElement('div');
              el.className = 'panel-error-inline';
              el.style.color = '#b00020';
              el.style.marginTop = '8px';
              container.prepend(el);
            }
            el.textContent = msg;
          }

          // try posting JSON to LoginSimple
          try {
            console.log('[login-intercept] POST /Account/LoginSimple', { Email: email });
            const tokenInput = form.querySelector('input[name="__RequestVerificationToken"]');
            const headers = { 'Content-Type': 'application/json' };
            if (tokenInput && tokenInput.value) headers['RequestVerificationToken'] = tokenInput.value;

            const res = await fetch('/Account/LoginSimple', {
              method: 'POST',
              credentials: 'same-origin',
              headers,
              body: JSON.stringify({ Email: email })
            });

            console.log('[login-intercept] response', res.status);
            let body = null;
            try { body = await res.json(); } catch(e) { body = null; }

            if (!res.ok) {
              console.warn('[login-intercept] non-ok', res.status, body);
              showInline((body && (body.message || body.error)) || ('Login failed: ' + res.status));
              return;
            }

            if (body && body.success) {
              console.log('[login-intercept] login success, redirecting to', body.redirectUrl || '/');
              window.location.href = body.redirectUrl || '/';
              return;
            }

            // fallback handling
            if (body && body.redirectUrl) {
              window.location.href = body.redirectUrl;
              return;
            }

            showInline('Unexpected result from server.');
          } catch (err) {
            console.error('[login-intercept] error', err);
            showInline('Network error — please try again.');
          }
        }, true /* useCapture to run before other listeners */);
      });
    })();
</script>
</body>
</html>
